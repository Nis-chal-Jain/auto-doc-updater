# Required: Google AI Studio / Gemini API key (server-side only)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: model id (see https://ai.google.dev/gemini-api/docs/models)
# GEMINI_MODEL=gemini-2.0-flash

# Required for GitHub OAuth login flow
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Optional fallback token for server-side calls when not signed in
# GITHUB_TOKEN=
